---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<section class="legal-section">
  <h2>{title}</h2>
  <div class="legal-body">
    <slot />
  </div>
</section>

<style>
  .legal-section {
    margin-bottom: 48px;
  }
  .legal-section h2 {
    font-size: 26px;
    margin-bottom: 18px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line);
  }
  .legal-body {
    font-size: 15.5px;
    color: var(--ink-2);
    line-height: 1.75;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .legal-body :global(ul) {
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin: 4px 0;
  }
  .legal-body :global(li) { line-height: 1.6; }
  .legal-body :global(p) { margin: 0; }
  .legal-body :global(b),
  .legal-body :global(strong) { color: var(--ink); }
</style>
