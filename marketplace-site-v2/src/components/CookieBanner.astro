---
// RGPD cookie banner. Shown until the user makes a choice
// (accept / essentials only). Client-side only — no tracking installed.
---

<div id="cookie-banner" class="cookie" role="dialog" aria-labelledby="cookie-title" hidden>
  <div class="cookie-body">
    <div id="cookie-title" class="cookie-title">🍋 Ce site utilise des cookies</div>
    <p class="cookie-text">
      Nous utilisons uniquement des cookies techniques nécessaires au fonctionnement du site.
      Aucun tracker publicitaire.
      <a href="/cookies">En savoir plus</a>
    </p>
  </div>
  <div class="cookie-actions">
    <button type="button" class="btn btn-lemon btn-sm" id="cookie-accept">Accepter</button>
    <button type="button" class="btn btn-ghost btn-sm cookie-ghost" id="cookie-essential">
      Essentiels seulement
    </button>
  </div>
</div>

<script is:inline>
  (function () {
    const banner = document.getElementById('cookie-banner');
    if (!banner) return;
    if (localStorage.getItem('lz-cookies')) return;
    banner.hidden = false;
    const close = function (choice) {
      localStorage.setItem('lz-cookies', choice);
      banner.hidden = true;
    };
    document.getElementById('cookie-accept')?.addEventListener('click', function () { close('accepted'); });
    document.getElementById('cookie-essential')?.addEventListener('click', function () { close('essential'); });
  })();
</script>

<style>
  .cookie {
    position: fixed;
    bottom: 20px;
    left: 20px;
    right: 20px;
    z-index: 9999;
    max-width: 560px;
    margin: 0 auto;
    background: var(--ink);
    color: var(--cream);
    border-radius: var(--r-lg);
    padding: 22px 26px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .cookie-title {
    font-family: var(--font-serif);
    font-size: 20px;
    margin-bottom: 6px;
  }
  .cookie-text {
    font-size: 13.5px;
    color: rgba(255, 248, 231, 0.72);
    line-height: 1.5;
    margin: 0;
  }
  .cookie-text a {
    color: var(--lemon);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .cookie-actions {
    display: flex;
    gap: 10px;
  }
  .cookie-actions .btn { flex: 1; justify-content: center; }
  .cookie-ghost {
    color: var(--cream);
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: transparent;
  }
  .cookie-ghost:hover { background: rgba(255, 255, 255, 0.06); color: var(--cream); }
  @media (max-width: 480px) {
    .cookie { bottom: 12px; left: 12px; right: 12px; padding: 18px 20px; }
    .cookie-actions { flex-direction: column; }
  }
</style>
