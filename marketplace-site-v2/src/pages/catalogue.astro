---
import Base from '@/layouts/Base.astro';
import ProductCard from '@/components/ProductCard.astro';
import CategoryChip from '@/components/CategoryChip.astro';
import { CATEGORIES, getAllProducts } from '@/lib/notion';

const products = await getAllProducts();

// Surface a small filter UI with plain anchor links — catalogue is static,
// so filtering via hash/JS would be a later enhancement. For now, the chips
// link to /metiers/<slug> for category deep-dives, and the main grid shows all.
const countByCat = new Map<string, number>();
for (const p of products) {
  for (const c of p.categories) countByCat.set(c, (countByCat.get(c) ?? 0) + 1);
}
---

<Base
  title="Catalogue — Tous les skills IA · Lemon Zest Digital"
  description="Parcourez tous les skills IA disponibles : marketing, compta, juridique, RH, ventes, support, ops et tech. Paiement unique, accès immédiat."
  current="catalogue"
>
  <section class="catalog-hero">
    <div class="container">
      <span class="eyebrow"><span class="eyebrow-dot"></span>Catalogue</span>
      <h1>
        {products.length} skill{products.length > 1 ? 's' : ''}
        <span style="font-style:italic; color: var(--ink-2);">pour bosser mieux</span>.
      </h1>
      <p class="lead">
        Tous nos skills IA prêts à l'emploi. Filtre par métier pour aller droit au but.
      </p>

      <div class="chips-row">
        <CategoryChip href="/catalogue" label="Tous" active={true} count={products.length} />
        {CATEGORIES.map((c) => (
          <CategoryChip
            href={`/metiers/${c.slug}`}
            emoji={c.emoji}
            label={c.label}
            count={countByCat.get(c.label) ?? 0}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="catalog-grid-section">
    <div class="container">
      {products.length === 0 ? (
        <div class="empty">
          <h3>Bientôt en ligne…</h3>
          <p>Les premiers skills arrivent très vite. Reviens d'ici quelques jours.</p>
          <a href="/" class="btn btn-ghost">Retour à l'accueil</a>
        </div>
      ) : (
        <div class="grid-3">
          {products.map((p) => <ProductCard product={p} />)}
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .catalog-hero {
    padding: 64px 0 32px;
  }
  .catalog-hero h1 {
    font-size: clamp(40px, 6vw, 72px);
    margin: 20px 0 16px;
  }
  .catalog-hero .lead {
    max-width: 56ch;
    color: var(--ink-2);
    font-size: 17px;
  }
  .chips-row {
    display: flex; flex-wrap: wrap;
    gap: 10px;
    margin-top: 32px;
  }
  .catalog-grid-section { padding: 32px 0 96px; }
  .empty {
    padding: 96px 32px;
    text-align: center;
    background: var(--paper);
    border: 1px dashed var(--line);
    border-radius: var(--r-lg);
  }
  .empty h3 { font-size: 28px; margin-bottom: 12px; }
  .empty p { color: var(--ink-3); margin-bottom: 24px; }
</style>
