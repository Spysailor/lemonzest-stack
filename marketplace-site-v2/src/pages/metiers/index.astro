---
import Base from '@/layouts/Base.astro';
import { CATEGORIES, getAllProducts } from '@/lib/notion';

const all = await getAllProducts();
const countByCat = new Map<string, number>();
for (const p of all) {
  for (const c of p.categories) countByCat.set(c, (countByCat.get(c) ?? 0) + 1);
}
---

<Base
  title="Par métier — 8 fonctions couvertes · Lemon Zest Digital"
  description="Marketing, compta, juridique, RH, ventes, support, ops, tech : choisis ton métier et trouve le skill IA conçu pour toi."
  current="metiers"
>
  <section class="section">
    <div class="container">
      <div class="section-head text-center" style="margin: 32px auto 48px; max-width: 680px;">
        <span class="eyebrow"><span class="eyebrow-dot"></span>Par métier</span>
        <h1 style="font-size: clamp(44px, 6vw, 80px); margin: 20px 0 16px;">
          8 métiers. <span style="font-style:italic; color: var(--ink-2);">Un skill par besoin.</span>
        </h1>
        <p style="font-size: 17px; color: var(--ink-2);">
          Chaque fonction a ses codes, ses outils, ses urgences.
          Choisis ton métier et on t'amène aux skills conçus pour toi.
        </p>
      </div>

      <div class="grid-4 metiers-grid">
        {CATEGORIES.map((c) => (
          <a href={`/metiers/${c.slug}`} class="card metier-card clickable">
            <div class="metier-emoji" aria-hidden="true">{c.emoji}</div>
            <div>
              <h3 class="metier-label">{c.label}</h3>
              <p class="metier-blurb">{c.blurb}</p>
            </div>
            <span class="mono-sm metier-count">
              {countByCat.get(c.label) ?? 0} skill{(countByCat.get(c.label) ?? 0) > 1 ? 's' : ''}
              <span class="icon-arrow" style="margin-left:6px;">→</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .section { padding: 56px 0 96px; }
  .metiers-grid { gap: 20px; }
  .metier-card {
    padding: 24px;
    display: flex; flex-direction: column; gap: 14px;
    text-decoration: none;
  }
  .metier-emoji {
    font-size: 32px;
    width: 56px; height: 56px;
    border-radius: 16px;
    background: var(--cream-2);
    display: flex; align-items: center; justify-content: center;
  }
  .metier-label { font-size: 22px; font-family: var(--font-serif); }
  .metier-blurb { font-size: 13.5px; color: var(--ink-3); line-height: 1.45; margin: 6px 0 0; }
  .metier-count {
    margin-top: auto;
    padding-top: 10px;
    border-top: 1px dashed var(--line);
    display: inline-flex; align-items: center;
    font-size: 12px;
  }
  .metier-card:hover .icon-arrow { transform: translateX(4px); }
</style>
