---
import Base from '@/layouts/Base.astro';
import ProductCard from '@/components/ProductCard.astro';
import CategoryChip from '@/components/CategoryChip.astro';
import { CATEGORIES, getAllProducts, categoryBySlug } from '@/lib/notion';
import type { Product } from '@/lib/notion';

export async function getStaticPaths() {
  const all = await getAllProducts();
  return CATEGORIES.map((c) => ({
    params: { cat: c.slug },
    props: {
      cat: c,
      products: all.filter((p) => p.categories.includes(c.label)),
      allCount: all.length,
    },
  }));
}

interface Props {
  cat: { slug: string; label: string; emoji: string; blurb: string };
  products: Product[];
  allCount: number;
}
const { cat, products } = Astro.props;
---

<Base
  title={`${cat.label} — Skills IA pour ${cat.label.toLowerCase()} · Lemon Zest Digital`}
  description={`Skills IA spécialisés ${cat.label.toLowerCase()} : ${cat.blurb}. Livraison immédiate, paiement unique, garantie 14 jours.`}
  current="metiers"
>
  <section class="metier-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Fil d'ariane">
        <a href="/">Accueil</a>
        <span aria-hidden="true">›</span>
        <a href="/catalogue">Catalogue</a>
        <span aria-hidden="true">›</span>
        <span>{cat.label}</span>
      </nav>

      <div class="metier-head">
        <div class="metier-big-emoji" aria-hidden="true">{cat.emoji}</div>
        <div>
          <span class="eyebrow"><span class="eyebrow-dot"></span>Par métier</span>
          <h1>
            Skills <span style="font-style:italic; color: var(--ink-2);">{cat.label}</span>.
          </h1>
          <p class="lead">{cat.blurb}.</p>
        </div>
      </div>

      <div class="chips-row">
        <CategoryChip href="/catalogue" label="Tous" />
        {CATEGORIES.map((c) => (
          <CategoryChip
            href={`/metiers/${c.slug}`}
            emoji={c.emoji}
            label={c.label}
            active={c.slug === cat.slug}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="metier-grid-section">
    <div class="container">
      {products.length === 0 ? (
        <div class="empty">
          <h3>{cat.emoji} Bientôt disponible</h3>
          <p>On prépare des skills dédiés <strong>{cat.label}</strong>. Écris-nous si tu as un besoin précis — on prendra ton cas en compte.</p>
          <div class="row gap-3 center" style="justify-content: center; margin-top: 20px;">
            <a href="/catalogue" class="btn btn-ghost">Voir tout le catalogue</a>
            <a href="mailto:contact@lemonzestdigital.com" class="btn btn-primary">Exprimer un besoin</a>
          </div>
        </div>
      ) : (
        <>
          <div class="grid-count mono-sm">
            {products.length} skill{products.length > 1 ? 's' : ''} disponible{products.length > 1 ? 's' : ''}
          </div>
          <div class="grid-3">
            {products.map((p) => <ProductCard product={p} />)}
          </div>
        </>
      )}
    </div>
  </section>
</Base>

<style>
  .metier-hero { padding: 56px 0 32px; }
  .breadcrumb {
    display: flex; gap: 8px; align-items: center;
    font-size: 13px; color: var(--ink-3);
    margin-bottom: 28px; flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--ink-2); }

  .metier-head {
    display: flex; gap: 28px; align-items: center;
    margin-bottom: 32px;
  }
  .metier-big-emoji {
    font-size: 56px;
    width: 96px; height: 96px;
    border-radius: 24px;
    background: var(--paper);
    border: 1px solid var(--line);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    box-shadow: var(--shadow-1);
  }
  .metier-head h1 {
    font-size: clamp(40px, 5.5vw, 72px);
    margin: 12px 0 8px;
  }
  .lead { font-size: 17px; color: var(--ink-2); max-width: 56ch; margin: 0; }

  .chips-row {
    display: flex; flex-wrap: wrap; gap: 10px;
    margin-top: 24px;
  }

  .metier-grid-section { padding: 32px 0 96px; }
  .grid-count { margin-bottom: 20px; }

  .empty {
    padding: 80px 32px;
    text-align: center;
    background: var(--paper);
    border: 1px dashed var(--line);
    border-radius: var(--r-lg);
  }
  .empty h3 { font-size: 28px; margin-bottom: 12px; }
  .empty p { color: var(--ink-3); max-width: 56ch; margin: 0 auto; }

  @media (max-width: 720px) {
    .metier-head { flex-direction: column; align-items: flex-start; gap: 16px; }
    .metier-big-emoji { width: 72px; height: 72px; font-size: 40px; border-radius: 18px; }
  }
</style>
