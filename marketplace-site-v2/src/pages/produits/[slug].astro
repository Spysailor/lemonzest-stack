---
import Base from '@/layouts/Base.astro';
import ProductCard from '@/components/ProductCard.astro';
import ProductVisual from '@/components/product/ProductVisual.astro';
import BeforeAfter from '@/components/product/BeforeAfter.astro';
import DemoSimulator from '@/components/product/DemoSimulator.astro';
import OutputGallery from '@/components/product/OutputGallery.astro';
import WhatItDoes from '@/components/product/WhatItDoes.astro';
import ProductFAQ from '@/components/product/ProductFAQ.astro';
import { getAllProducts, formatPrice, categorySlug } from '@/lib/notion';
import { getProductContent } from '@/data/product-content';
import type { Product } from '@/lib/notion';

export async function getStaticPaths() {
  const products = await getAllProducts();
  return products.map((p) => ({
    params: { slug: p.slug },
    props: { product: p, all: products },
  }));
}

interface Props { product: Product; all: Product[] }
const { product, all } = Astro.props;

const isLive = product.status === 'Live';
const hasBuy = isLive && !!product.gumroadSlug;

// Related: same first category, excl self, max 3
const firstCat = product.categories[0];
const related = all
  .filter((p) => p.id !== product.id && (firstCat ? p.categories.includes(firstCat) : false))
  .slice(0, 3);

const badgeClass =
  product.badge === 'Nouveau'      ? 'tag tag-lemon' :
  product.badge === 'Best-seller'  ? 'tag tag-zest'  :
  product.badge === 'Promo'        ? 'tag tag-promo' :
  product.badge === 'Beta'         ? 'tag tag-beta'  :
  null;

const buyUrl = product.gumroadUrl ?? '/acheter';
const content = getProductContent(product.slug, product.categories);
---

<Base
  title={`${product.name} — ${formatPrice(product.price, product.currency)} · Lemon Zest Digital`}
  description={product.tagline || `${product.name} — skill IA prêt à l'emploi`}
  ogImage={product.coverUrl ?? '/og-default.png'}
>
  <!-- ═══════════════════════ HERO ═══════════════════════ -->
  <section class="product-hero">
    <div class="container">

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Fil d'ariane">
        <a href="/">Accueil</a>
        <span aria-hidden="true">›</span>
        <a href="/catalogue">Catalogue</a>
        {firstCat && (
          <>
            <span aria-hidden="true">›</span>
            <a href={`/metiers/${categorySlug(firstCat)}`}>{firstCat}</a>
          </>
        )}
      </nav>

      <!-- 2 colonnes : visuel | sidebar sticky -->
      <div class="product-grid">

        <!-- LEFT : Visuel -->
        <div class="product-media">
          <ProductVisual product={product} />
          {product.galleryUrls.length > 0 && (
            <div class="gallery">
              {product.galleryUrls.map((url, i) => (
                <img src={url} alt={`${product.name} — visuel ${i + 1}`} loading="lazy" />
              ))}
            </div>
          )}
        </div>

        <!-- RIGHT : Info + prix (sticky) -->
        <aside class="product-sidebar">
          <!-- Tags -->
          <div class="product-head">
            {product.categories.map((c) => (
              <a href={`/metiers/${categorySlug(c)}`} class="tag">{c}</a>
            ))}
            {product.type && <span class="tag tag-leaf">{product.type}</span>}
            {badgeClass && <span class={badgeClass}>{product.badge}</span>}
            {!isLive && <span class="tag tag-soon">Bientôt</span>}
          </div>

          <h1 class="product-name">{product.name}</h1>
          {product.tagline && <p class="tagline">{product.tagline}</p>}

          {product.bullets.length > 0 && (
            <ul class="bullets">
              {product.bullets.map((b) => <li>{b}</li>)}
            </ul>
          )}

          <!-- Prix box -->
          <div class="price-block">
            <div class="price-row">
              <span class="price">{formatPrice(product.price, product.currency)}</span>
              <span class="mono-sm">paiement unique</span>
            </div>

            {hasBuy ? (
              <a href={buyUrl} class="btn btn-lemon btn-lg buy-cta" target="_blank" rel="noopener">
                Acheter maintenant <span>→</span>
              </a>
            ) : (
              <span class="btn btn-ghost btn-lg" aria-disabled="true">Bientôt disponible</span>
            )}

            <ul class="guarantees">
              <li>✓ Livraison immédiate par email</li>
              <li>✓ Garantie 14 jours satisfait ou remboursé</li>
              <li>✓ Mises à jour incluses à vie</li>
              <li>✓ Compatible Claude · ChatGPT · Cursor</li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ AVANT / APRÈS ═══════════════════════ -->
  <BeforeAfter
    skillName={product.name}
    beforeOutput={content.beforeOutput}
    beforeVerdict={content.beforeVerdict}
    afterOutput={content.afterOutput}
    afterVerdict={content.afterVerdict}
  />

  <!-- ═══════════════════════ DÉMO INTERACTIVE ═══════════════════════ -->
  <DemoSimulator
    skillName={product.name}
    conversation={content.demo}
  />

  <!-- ═══════════════════════ GALERIE OUTPUTS ═══════════════════════ -->
  <OutputGallery outputs={content.outputs} />

  <!-- ═══════════════════════ CE QU'IL FAIT ═══════════════════════ -->
  <WhatItDoes product={product} />

  <!-- ═══════════════════════ FAQ ═══════════════════════ -->
  <ProductFAQ />

  <!-- ═══════════════════════ RELATED ═══════════════════════ -->
  {related.length > 0 && (
    <section class="section section-alt">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow"><span class="eyebrow-dot"></span>Dans la même veine</span>
          <h2>Tu pourrais aussi aimer.</h2>
        </div>
        <div class="grid-3">
          {related.map((p) => <ProductCard product={p} />)}
        </div>
      </div>
    </section>
  )}
</Base>

<style>
  /* ── Hero section ────────────────────────────────────────────── */
  .product-hero { padding: 32px 0 64px; }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--ink-3);
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--ink-2); }
  .breadcrumb a:hover { color: var(--ink); }

  /* 2-col layout */
  .product-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 56px;
    align-items: start;
  }

  /* Visual — pas sticky, les sections défilent sous */
  .product-media { display: flex; flex-direction: column; gap: 12px; }

  .gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }
  .gallery img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: var(--r-sm);
    border: 1px solid var(--line);
  }

  /* Sidebar — STICKY */
  .product-sidebar {
    position: sticky;
    top: 96px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .product-head { display: flex; flex-wrap: wrap; gap: 8px; }

  .product-name {
    font-size: clamp(32px, 4.5vw, 52px);
    line-height: 1.05;
    margin: 0;
  }
  .tagline {
    font-size: 17px;
    color: var(--ink-2);
    line-height: 1.5;
    margin: 0;
  }

  .bullets {
    display: flex;
    flex-direction: column;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 14.5px;
    color: var(--ink-2);
  }
  .bullets li {
    padding-left: 26px;
    position: relative;
    line-height: 1.5;
  }
  .bullets li::before {
    content: '✓';
    position: absolute;
    left: 0;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--lemon-pale);
    color: var(--lemon-deep);
    font-size: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    top: 2px;
  }

  /* Prix box */
  .price-block {
    padding: 24px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .price-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }
  .price {
    font-family: var(--font-serif);
    font-size: 42px;
    line-height: 1;
  }
  .buy-cta { justify-content: center; }

  .guarantees {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 12.5px;
    color: var(--ink-3);
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .product-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .product-sidebar {
      position: static;
    }
  }
</style>
