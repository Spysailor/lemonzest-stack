# Notion integration — build-time fetch of Marketplace Catalogue DB
# Create at https://www.notion.so/profile/integrations (Internal integration)
# Grant access to the DB 🛒 Marketplace — Catalogue Produits + 🎯 Skills Curator (Connections menu)
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxx

# Database ID of 🛒 Marketplace — Catalogue Produits (stable, safe to commit)
NOTION_PRODUCTS_DATABASE_ID=5db08076-eb22-4dda-bb2e-304647ec2501

# Gumroad domain — used to build checkout URLs from {Gumroad Slug}
GUMROAD_SUBDOMAIN=lemonzestdigital
