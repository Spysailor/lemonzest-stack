# Template des variables d'environnement locales.
# Copier en .env (non commité) et remplir avec les vraies valeurs.
#
#   cp .env.example .env

# --- Notion (IDs de bases / pages) --------------------------------------------
# Remplir avec les vrais IDs depuis ton .env local
NOTION_DB_ID_SKILLS_CURATOR=
NOTION_DB_ID_CRM_LANCEMENT=
NOTION_PAGE_ID_PILOTAGE=
NOTION_DB_ID_ROUTINES=

# --- VPS (garder en local seulement) -----------------------------------------
VPS_IP=
VPS_USER=root

# --- GitHub -------------------------------------------------------------------
GITHUB_USER=Spysailor
GITHUB_REPO=lemonzest-stack

# --- Gumroad ------------------------------------------------------------------
GUMROAD_API_KEY=
GUMROAD_PRODUCT_SLUG=

# --- Brevo --------------------------------------------------------------------
BREVO_API_KEY=

# --- Skill Factory Pipeline ---------------------------------------------------
# Token d'intégration Notion (https://www.notion.so/my-integrations)
# L'intégration doit être invitée dans la base Skills Curator (Share → Invite).
NOTION_TOKEN=
# Clé API Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=
# Modèle Claude et cap de tokens
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_MAX_TOKENS=8000
# Bot Telegram pour le rapport de fin de batch (optionnel)
#   Créer : @BotFather → /newbot ; chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Rate limiting entre skills (secondes) et chemins de sortie
RATE_LIMIT_SECONDS=30
# SKILLS_OUTPUT_DIR=~/lemonzest-stack/skills
# ZIPS_OUTPUT_DIR=~/lemonzest-stack/zips
# SKILL_FACTORY_PATH=~/.claude/skills/skill-fr-factory/SKILL.md

# --- Domaine ------------------------------------------------------------------
DOMAIN=lemonzest.digital
MARKETPLACE_SUBDOMAIN=marketplace.lemonzestdigital.com

# --- Société ------------------------------------------------------------------
BRN=
COMPANY_NAME="Lemon Zest Digital"
COMPANY_EMAIL=contact@lemonzest.digital
