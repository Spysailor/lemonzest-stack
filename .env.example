# Template des variables d'environnement locales.
# Copier en .env (non commité) et remplir avec les vraies valeurs.
#
#   cp .env.example .env

# --- Notion (IDs de bases / pages) --------------------------------------------
# Remplir avec les vrais IDs depuis ton .env local
NOTION_DB_ID_SKILLS_CURATOR=
NOTION_DB_ID_CRM_LANCEMENT=
NOTION_PAGE_ID_PILOTAGE=
NOTION_DB_ID_ROUTINES=

# --- VPS (garder en local seulement) -----------------------------------------
VPS_IP=
VPS_USER=root

# --- GitHub -------------------------------------------------------------------
GITHUB_USER=Spysailor
GITHUB_REPO=lemonzest-stack

# --- Gumroad ------------------------------------------------------------------
GUMROAD_API_KEY=
GUMROAD_PRODUCT_SLUG=

# --- Brevo --------------------------------------------------------------------
BREVO_API_KEY=

# --- Domaine ------------------------------------------------------------------
DOMAIN=lemonzest.digital
MARKETPLACE_SUBDOMAIN=marketplace.lemonzestdigital.com

# --- Société ------------------------------------------------------------------
BRN=
COMPANY_NAME="Lemon Zest Digital"
COMPANY_EMAIL=contact@lemonzest.digital
