# Private files — never commit these
.private/
.env
.env.*
!.env.example

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
.next/
.nuxt/
out/
build/

# Exception: marketplace-site-v2 dist IS committed (VPS serves it via bind-mount)
!marketplace-site-v2/dist/
!marketplace-site-v2/dist/**

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Claude / AI tools
.claude/

# Hosting
.vercel/
.netlify/

# Misc
*.zip
*.tar.gz

# Skill Factory — outputs régénérables (SKILL.md FR, ZIPs, logs, rapports)
# Les sources (skill-fr-factory/, script automation) restent versionnées.
logs/
zips/
skills/*-fr/
# Garde l'option de commit explicite d'un skill FR finalisé :
# !skills/marketing-agence-fr/
